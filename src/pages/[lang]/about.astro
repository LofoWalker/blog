---
import Base from '../../layouts/Base.astro';
import type { Lang } from '../../i18n/ui';
import { langs, useTranslations } from '../../i18n/ui';
import { localizedPath } from '../../i18n/utils';

export function getStaticPaths() {
  return langs.map((lang) => ({ params: { lang }, props: { lang } }));
}

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<Base title={t('about.eyebrow')} description={lang === 'fr' ? 'À propos de Tom Walker — ingénieur logiciel.' : 'About Tom Walker — software engineer.'} lang={lang}>
  <section class="container page-head rise">
    <p class="eyebrow">{t('about.eyebrow')}</p>
    <h1>{t('about.name')}</h1>
  </section>

  <article class="container reading prose section">
    <p class="lead">{t('about.lead')}</p>

    <p>{t('about.p1')}</p>

    <p>
      {t('about.p2.intro')}
      {' '}<a href={localizedPath(lang, '/projects')}>{t('about.p2.projects')}</a>{' '}
      {t('about.p2.mid')}
      {' '}<a href={localizedPath(lang, '/articles')}>{t('about.p2.articles')}</a>{' '}
      {t('about.p2.end')}
    </p>
  </article>
</Base>

<style>
  .page-head {
    padding-top: clamp(40px, 6vw, 80px);
  }

  .page-head h1 {
    margin-top: var(--space-2);
  }
</style>

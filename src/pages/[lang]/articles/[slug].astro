---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import type { Lang } from '../../../i18n/ui';
import { useTranslations } from '../../../i18n/ui';
import { localizedPath, formatDate, getLocaleSlug } from '../../../i18n/utils';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles
    .filter((a) => !a.data.draft)
    .map((entry) => {
      const [locale, slug] = entry.id.split('/');
      return {
        params: { lang: locale, slug },
        props: { entry, lang: locale as Lang },
      };
    });
}

interface Props { entry: Awaited<ReturnType<typeof getCollection<'articles'>>>[number]; lang: Lang }
const { entry, lang } = Astro.props;
const { Content } = await render(entry);
const t = useTranslations(lang);

const allArticles = await getCollection('articles');
const altLang = lang === 'fr' ? 'en' : 'fr';
const twin = allArticles.find(
  (a) => a.data.translationKey === entry.data.translationKey && a.id.startsWith(`${altLang}/`),
);
const altLangUrl = twin
  ? localizedPath(altLang, `/articles/${getLocaleSlug(twin.id)}`)
  : localizedPath(altLang, '/articles');
---

<Base title={entry.data.title} description={entry.data.summary} lang={lang} altLangUrl={altLangUrl}>
  <article class="container">
    <header class="reading article-head rise">
      <a class="meta back" href={localizedPath(lang, '/articles')}>{t('articles.back')}</a>
      <h1>{entry.data.title}</h1>
      <p class="lead article-summary">{entry.data.summary}</p>
      <p class="meta">{formatDate(entry.data.date, lang)}</p>
    </header>

    <div class="reading prose section">
      <Content />
    </div>
  </article>
</Base>

<style>
  .article-head {
    padding-top: var(--space-6);
  }

  .back {
    display: inline-block;
    margin-bottom: var(--space-6);
    transition: color var(--dur) var(--ease);
  }

  .back:hover {
    color: var(--text);
  }

  .article-head h1 {
    margin-bottom: var(--space-3);
  }

  .article-summary {
    margin-bottom: var(--space-3);
  }
</style>
